{
  "name": "cutflow-video-tool",
  "version": "1.53.0",
  "private": true,
  "description": "A friendly cross-platform video cutter and converter",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:web": "vite build",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "1.1.0",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "1.25.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "8.1.5",
    "wait-on": "9.0.10"
  },
  "build": {
    "appId": "com.cutflow.desktop",
    "productName": "剪影工坊 v1.53",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "剪影工坊-v1.53-Windows.${ext}",
      "extraResources": [
        {
        "from": "node_modules/.pnpm/ffmpeg-static@5.3.0/node_modules/ffmpeg-static/ffmpeg.exe",
          "to": "ffmpeg.exe"
        },
        {
          "from": "assets/luts",
          "to": "luts"
        }
      ]
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.video",
      "artifactName": "剪影工坊-v1.53-macOS-${arch}.${ext}",
      "identity": null,
      "extraResources": [
        {
          "from": "ffmpeg-macos",
          "to": "ffmpeg"
        },
        {
          "from": "assets/luts",
          "to": "luts"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}
